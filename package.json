    "next": "^14.2.0",
    "next-auth": "^5.0.0-beta.30",
    "openai": "^6.32.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "resend": "^6.9.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
