# =============================================================================
# GEO Analyzer — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# .env.local is git-ignored and should never be committed.
# =============================================================================


# -----------------------------------------------------------------------------
# ANTHROPIC API KEY (optional — server-side)
# -----------------------------------------------------------------------------
# By default, GEO Analyzer asks each user to enter their own Anthropic API key
# in the browser UI. No server-side key is required for that mode.
#
# Set this variable if you want to run in "hosted" mode — where the key is
# stored on the server and hidden from users (e.g. a private internal tool or
# a SaaS deployment where you bill users separately).
#
# When set, update /app/api/analyze/route.ts to read from process.env instead
# of the apiKey field in the request body.
#
# Get your key at: https://console.anthropic.com
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...


# -----------------------------------------------------------------------------
# APP URL
# -----------------------------------------------------------------------------
# The canonical public URL of the deployed app.
# Used for absolute URL generation, Open Graph metadata, and sitemap roots.
# No trailing slash.
#
# Examples:
#   http://localhost:3000          (local development)
#   https://geo.yourdomain.com    (production)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# NODE ENVIRONMENT (set automatically by Next.js — do not set manually)
# -----------------------------------------------------------------------------
# Next.js sets NODE_ENV to "development", "test", or "production" automatically
# based on the command used (next dev / next build / next start).
# You do not need to define it here.
# -----------------------------------------------------------------------------
